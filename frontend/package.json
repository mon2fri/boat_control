{
  "name": "boat-control-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:inspect": "vitest run tests/buildInspection.test.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:fixture": "cd .. && DJANGO_SETTINGS_MODULE=boat_control.settings PYTHONPATH=backend uv run python tests/integration/run_e2e_workflow.py --output frontend/tests/integration-fixtures/e2e_responses.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-virtual": "^3.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}
