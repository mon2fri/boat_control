.idea/
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
__pycache__/
*.py[cod]
.coverage
.coverage.*
htmlcov/

# Node modules — never at the repo root; only inside the frontend workspace.
node_modules/
frontend/node_modules/

# Frontend build outputs and test reports.
frontend/dist/
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/
frontend/.vite/

# TypeScript incremental build info.
*.tsbuildinfo

# Runtime artefacts. These are gitignored so the working tree contains
# only fixtures under tests/. Developers regenerate them locally.
data/uploads/*
!data/uploads/.gitkeep
data/results/*
!data/results/.gitkeep
data/*.sqlite3
data/playwright/

# OS / editor noise.
.DS_Store
Thumbs.db
